#!/usr/bin/env bash
set -euo pipefail
PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd $PROJECT_DIR
$PROJECT_DIR/bin/env/java-setup
$PROJECT_DIR/bin/env/clojure-setup
clojure -Spom

echo ">o> uberjar1"
#clojure -A:depstar:resources -m hf.depstar.uberjar leihs-inventory.jar -C -m leihs.inventory.server.main
clojure -X:uberjar
echo ">o> uberjar2"
